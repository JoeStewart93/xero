# Xero local/lab defaults for Docker Compose.
# Copy to .env only when you need to override these values.

APP_ENV=development
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000

# Local UI/BFF stack. Start with:
# docker compose -f docker-compose.bff.yml up -d --build
BFF_SERVICE_NAME=xero-bff
BFF_POSTGRES_DB=xero_bff
BFF_POSTGRES_USER=xero_bff
BFF_POSTGRES_PASSWORD=xero_bff_password
DATABASE_URL=postgresql://xero_bff:xero_bff_password@bff-postgres:5432/xero_bff
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
REDIS_URL=redis://bff-redis:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_RATE_LIMIT_ENABLED=true
REDIS_RATE_LIMIT_REQUESTS=120
REDIS_RATE_LIMIT_WINDOW_SECONDS=60
BACKEND_PORT=8000

# Local operator seed and JWT settings.
# Change these values before using any non-local environment.
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=operator_password
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin
JWT_SECRET_KEY=dev-only-xero-jwt-secret-change-me
JWT_EXPIRES_MINUTES=60
BCRYPT_ROUNDS=12

# Separate C2 API stack. Start with:
# docker compose -f docker-compose.c2.yml up -d --build
C2_BACKEND_PORT=8001
C2_SERVICE_NAME=xero-c2-core
C2_POSTGRES_DB=xero_c2
C2_POSTGRES_USER=xero_c2
C2_POSTGRES_PASSWORD=xero_c2_password
C2_DATABASE_URL=postgresql://xero_c2:xero_c2_password@c2-postgres:5432/xero_c2
C2_DATABASE_POOL_SIZE=5
C2_DATABASE_MAX_OVERFLOW=10
C2_DATABASE_POOL_TIMEOUT_SECONDS=30
C2_DATABASE_POOL_RECYCLE_SECONDS=1800
C2_REDIS_URL=redis://c2-redis:6379/0
C2_REDIS_MAX_CONNECTIONS=20
C2_CONNECT_PASSWORD=c2_password
C2_TOKEN_EXPIRES_MINUTES=480
C2_JWT_SECRET_KEY=dev-only-xero-jwt-secret-change-me
C2_PROTOCOL_PRIVATE_KEY_B64=AQIDBAUGBwgJCgsMDQ4PEBESExQVFhcYGRobHB0eHyA=
C2_PROTOCOL_FRAME_HARNESS_ENABLED=false
C2_PROTOCOL_MAX_FRAME_BYTES=1048576
C2_PROTOCOL_SUPPORTED_VERSIONS=1
C2_BEACON_WS_SEND_QUEUE_SIZE=32
C2_BEACON_WS_REGISTRATION_TIMEOUT_SECONDS=5
C2_BEACON_WS_HEARTBEAT_TIMEOUT_SECONDS=90
C2_BEACON_WS_PING_INTERVAL_SECONDS=30
C2_BEACON_WS_PING_TIMEOUT_SECONDS=30
C2_BEACON_WS_MAX_MESSAGE_BYTES=1048576
C2_BEACON_LONGPOLL_TIMEOUT_SECONDS=60
C2_BEACON_LONGPOLL_MAX_FRAME_BYTES=1048576
BEACON_DEFAULT_SLEEP_SECONDS=30
BEACON_DEFAULT_JITTER=0.1
BEACON_HEARTBEAT_CHECK_INTERVAL_SECONDS=30
BEACON_STALE_THRESHOLD_MULTIPLIER=3
# Optional override. Leave unset to use BEACON_STALE_THRESHOLD_MULTIPLIER * per-beacon sleep.
# BEACON_STALE_THRESHOLD_SECONDS=90
WORKER_PAIRING_TOKEN_EXPIRES_MINUTES=15
WORKER_HEARTBEAT_INTERVAL_SECONDS=10
WORKER_STALE_THRESHOLD_SECONDS=30
C2_LOCAL_PROVISIONING_ENABLED=true
C2_WORKER_CONNECT_URL=http://host.docker.internal:8001
C2_PROVISIONING_PLATFORM_ROOT=/workspace/platform
C2_PROVISIONING_PROJECT_PREFIX=xero-managed
C2_BEACON_BUILDS_ENABLED=true
C2_BEACON_BUILD_TIMEOUT_SECONDS=180
C2_BEACON_BUILD_GO_IMAGE=golang:1.26
C2_ARTIFACT_STORAGE_BACKEND=s3
C2_ARTIFACT_S3_ENDPOINT_URL=http://c2-minio:9000
C2_ARTIFACT_S3_BUCKET=xero-artifacts
C2_ARTIFACT_S3_REGION=us-east-1
C2_ARTIFACT_S3_ACCESS_KEY=xero_minio
C2_ARTIFACT_S3_SECRET_KEY=xero_minio_password
C2_ARTIFACT_S3_PREFIX=c2
C2_ARTIFACT_FILESYSTEM_DIR=artifacts
C2_MINIO_API_PORT=9000
C2_MINIO_CONSOLE_PORT=9001

# External beacon handler scaffold.
HANDLER_SERVICE_NAME=xero-beacon-handler
HANDLER_PORT=8002

# External scanner scaffold.
SCANNER_SERVICE_NAME=xero-scanner
SCANNER_PORT=8003

# Optional worker pairing overrides used by handler/scanner compose runs.
C2_BASE_URL=
WORKER_PAIRING_TOKEN=
WORKER_NAME=
WORKER_ENDPOINT=
WORKER_CAPACITY=1

# Frontend service settings.
FRONTEND_PORT=3000
# Empty uses the frontend container's nginx same-origin proxy to bff-api.
VITE_API_BASE_URL=
VITE_DEFAULT_C2_BASE_URL=http://localhost:8001
